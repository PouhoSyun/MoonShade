PORT=3000
TZ=Asia/Shanghai
NODE_ENV=production
MOONSHADE_DATA_FILE=data/moonshade.json
MOONSHADE_ADMIN_EMAIL=admin
MOONSHADE_ADMIN_PASSWORD=replace-with-a-strong-password

MOONSHADE_MAIL_TRANSPORT=smtp
MOONSHADE_SMTP_HOST=smtp-relay.brevo.com
MOONSHADE_SMTP_PORT=465
MOONSHADE_SMTP_SECURE=true
MOONSHADE_SMTP_USER=your-brevo-smtp-login
MOONSHADE_SMTP_PASS=your-brevo-smtp-key
MOONSHADE_SMTP_FROM=your-verified-sender@example.com
MOONSHADE_SMTP_FROM_NAME=MoonShade

# 本地开发如需在页面显示验证码，可设置：
# NODE_ENV=development
# MOONSHADE_ALLOW_DEV_CODE=1
